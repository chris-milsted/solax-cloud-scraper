# Solax Cloud API credentials
SOLAX_TOKEN=your-solax-token-id
SOLAX_WIFI_SN=your-wifi-sn

# How often to poll (seconds). The inverter only updates every ~5 minutes.
POLL_INTERVAL_SECONDS=300

# InfluxDB — used by the collector, docker-compose init, and Grafana provisioning
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=change-me-use-a-long-random-string
INFLUX_ORG=solar
INFLUX_BUCKET=solar

# InfluxDB Docker init credentials
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=changeme123

# Grafana admin credentials
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme123
